// function to calculate built-up area
function builtArea(img){
  return ee.Image.pixelArea()
    .updateMask(img.eq(1))
    .reduceRegion({
      reducer: ee.Reducer.sum(),
      geometry: studyArea.geometry(),
      scale: 200,       // large scale prevents memory errors
      bestEffort: true
    })
    .getNumber('area')
    .divide(1000000);   // convert to km²
}


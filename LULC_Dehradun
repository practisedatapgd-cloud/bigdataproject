function runClick(coords){

  var point = ee.Geometry.Point(coords.lon, coords.lat);

  marker1.setEeObject(point);
  marker2.setEeObject(point);

  infoPanel.clear();

  // Location
  infoPanel.add(ui.Label('Location',{fontWeight:'bold'}));
  infoPanel.add(ui.Label('Lon: '+coords.lon.toFixed(4)));
  infoPanel.add(ui.Label('Lat: '+coords.lat.toFixed(4)));

  infoPanel.add(ui.Button('Reset',function(){
    infoPanel.clear();
    infoPanel.add(ui.Label('Click map to analyze'));
  }));


  //------------------------------------------------
  // CLASS VALUES
  //------------------------------------------------

  function getClass(img,label){

    img.sample({
      region:point,
      scale:30,
      numPixels:1
    }).evaluate(function(res){

      if(res.features.length>0){

        var c = res.features[0].properties.classification;

        var names = {
          1:'Built-up',
          2:'Forest',
          3:'Cropland',
          4:'Barren',
          5:'Water'
        };

        infoPanel.add(ui.Label(label+': '+names[c]));
      }

    });
  }

  getClass(leftMap.layers().get(1).getEeObject(),'Before');
  getClass(rightMap.layers().get(1).getEeObject(),'After');


  //------------------------------------------------
  // PIE CHARTS
  //------------------------------------------------

  function makeChart(img,title){

    var hist = img.reduceRegion({
      reducer:ee.Reducer.frequencyHistogram(),
      geometry:point.buffer(1000),
      scale:30,
      bestEffort:true
    });

    var d = ee.Dictionary(hist.get('classification'));

    var f = ee.Feature(null,{
      'Built-up':d.get('1',0),
      'Forest':d.get('2',0),
      'Cropland':d.get('3',0),
      'Barren':d.get('4',0),
      'Water':d.get('5',0)
    });

    return ui.Chart.feature.byProperty(f)
    .setChartType('PieChart')
    .setOptions({
      title:title,
      slices:{
        0:{color:'red'},
        1:{color:'006400'},
        2:{color:'ffff00'},
        3:{color:'c2b280'},
        4:{color:'419BDF'}
      }
    });
  }

  infoPanel.add(makeChart(
    leftMap.layers().get(1).getEeObject(),
    'Before (1 km)'
  ));

  infoPanel.add(makeChart(

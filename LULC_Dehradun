//================================================
// 17.6 EXPORT LULC CLASS AREA (ALL YEARS)
//================================================

function classArea(img, year){

  var area = ee.Image.pixelArea().addBands(img)
    .reduceRegion({
      reducer: ee.Reducer.sum().group({
        groupField: 1,
        groupName: 'class'
      }),
      geometry: studyArea,
      scale: 30,
      bestEffort: true
    });

  var groups = ee.List(area.get('groups'));

  return ee.FeatureCollection(groups.map(function(g){
    g = ee.Dictionary(g);
    return ee.Feature(null,{
      Year: year,
      Class: g.get('class'),
      Area_km2: ee.Number(g.get('sum')).divide(1e6)
    });
  }));
}

// Merge all years
var allStats = classArea(class1995,1995)
.merge(classArea(class2000,2000))
.merge(classArea(class2010,2010))
.merge(classArea(class2020,2020))
.merge(classArea(class2025,2025));

Export.table.toDrive({
  collection: allStats,
  description: 'LULC_Class_Area_All_Years',
  fileFormat: 'CSV'
});
